---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Print Studio Gráfico | Soluciones Digitales",
	description = "Diseño gráfico, identidad visual, marketing digital y más. Ideas que conectan, resultados que destacan.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link
			href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		/* Colores de marca - Print Studio Gráfico */
		--color-magenta: #e6007e;
		--color-blue: #00aeef;
		--color-yellow: #ffc20e;
		--color-black: #1a1a2e;
		--color-white: #ffffff;
		--color-gray-light: #f7f7f9;
		--color-gray: #6b6b7b;

		/* Tipografía */
		--font-main: "Poppins", sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		width: 100%;
		font-family: var(--font-main);
		color: var(--color-black);
		background-color: var(--color-white);
		scroll-behavior: smooth;
	}

	h1,
	h2,
	h3,
	h4 {
		margin: 0;
		font-weight: 700;
	}

	p {
		margin: 0;
	}

	a {
		text-decoration: none;
		color: inherit;
	}

	img {
		max-width: 100%;
		display: block;
	}
</style>