---
---

<section class="feature">
	<div class="feature-visual" aria-hidden="true">
		<span class="feature-visual-label">Fotografía de producto</span>
	</div>
	<div class="feature-text">
		<h2 class="feature-title">
			Tu marca, <span class="feature-highlight">nuestra pasión</span>
		</h2>
		<p class="feature-description">
			Soluciones digitales integrales que impulsan resultados reales
			para tu negocio.
		</p>
		<a href="#contacto" class="feature-cta">
			Hablemos
			<span class="feature-cta-arrow">→</span>
		</a>
	</div>
</section>

<style>
	.feature {
		display: grid;
		grid-template-columns: 1fr;
		min-height: 50vh;
	}

	.feature-visual {
		background: linear-gradient(
			135deg,
			var(--color-black) 0%,
			var(--color-magenta) 60%,
			var(--color-blue) 100%
		);
		display: flex;
		align-items: flex-end;
		padding: 2rem;
		min-height: 260px;
	}

	.feature-visual-label {
		color: var(--color-white);
		font-weight: 700;
		font-size: 0.85rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		opacity: 0.85;
	}

	.feature-text {
		background: var(--color-white);
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 3rem 1.5rem;
	}

	.feature-title {
		font-size: clamp(1.8rem, 4vw, 2.6rem);
		line-height: 1.2;
		color: var(--color-black);
		margin-bottom: 1rem;
	}

	.feature-highlight {
		color: var(--color-blue);
		font-style: italic;
	}

	.feature-description {
		color: var(--color-gray);
		font-size: 1rem;
		line-height: 1.6;
		max-width: 420px;
		margin-bottom: 1.75rem;
	}

	.feature-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		align-self: flex-start;
		border: 2px solid var(--color-black);
		color: var(--color-black);
		font-weight: 700;
		font-size: 0.9rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		padding: 0.8rem 1.6rem;
		border-radius: 999px;
		transition: background 0.25s ease, color 0.25s ease;
	}

	.feature-cta:hover {
		background: var(--color-black);
		color: var(--color-white);
	}

	.feature-cta-arrow {
		transition: transform 0.25s ease;
	}

	.feature-cta:hover .feature-cta-arrow {
		transform: translateX(4px);
	}

	@media (min-width: 900px) {
		.feature {
			grid-template-columns: 1fr 1fr;
		}
	}
</style>
