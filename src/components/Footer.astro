---
import logo from "../assets/logo.png";
import { Image } from "astro:assets";
import { Phone, Mail, MapPin } from "@lucide/astro";

const currentYear = new Date().getFullYear();

// TODO: Reemplaza estos datos con la información real de Print Studio Gráfico
const contact = {
	whatsapp: "https://wa.me/573001234567", // <- Cambia por el número real (formato: 57 + número, sin espacios ni +)
	instagram: "https://instagram.com/printstudiografico", // <- Cambia por el usuario real
	email: "Printstudiografico@gmail.com", // <- Cambia por el email real
	location: "Barranquilla, Colombia", // <- Cambia por la ciudad real
};

const quickLinks = [
	{ label: "Inicio", href: "#inicio" },
	{ label: "Servicios", href: "#servicios" },
	{ label: "Nosotros", href: "#nosotros" },
	{ label: "Contacto", href: "#contacto" },
];
---

<footer class="footer">
	<div class="footer-inner">
		<div class="footer-brand">
			<div class="footer-logo">
				<Image src={logo} alt="Print Studio Gráfico" width={40} height={40} />
				<span class="footer-logo-text">
					PRINT<span class="footer-logo-thin">STUDIO GRÁFICO</span>
				</span>
			</div>
			<p class="footer-tagline">
				Soluciones creativas y estratégicas para impulsar tu marca
				en el mundo digital.
			</p>
			<div class="footer-socials">
				<a href={contact.instagram} target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Instagram">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
						<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
						<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
						<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
					</svg>
				</a>
				<a href={contact.whatsapp} target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="WhatsApp">
					<Phone size={20} strokeWidth={1.75} />
				</a>
			</div>
		</div>

		<div class="footer-links">
			<h4 class="footer-heading">Navegación</h4>
			<ul class="footer-list">
				{quickLinks.map((link) => (
					<li><a href={link.href} class="footer-link">{link.label}</a></li>
				))}
			</ul>
		</div>

		<div class="footer-contact-block" id="contacto">
			<h4 class="footer-heading">Contacto</h4>
			<ul class="footer-list">
				<li class="footer-contact-item">
					<Mail size={16} strokeWidth={1.75} />
					<a href={`mailto:${contact.email}`} class="footer-link">{contact.email}</a>
				</li>
				<li class="footer-contact-item">
					<Phone size={16} strokeWidth={1.75} />
					<a href={contact.whatsapp} target="_blank" rel="noopener noreferrer" class="footer-link">WhatsApp</a>
				</li>
				<li class="footer-contact-item">
					<MapPin size={16} strokeWidth={1.75} />
					<span>{contact.location}</span>
				</li>
			</ul>
		</div>
	</div>

	<div class="footer-bottom">
		<p>&copy; {currentYear} Print Studio Gráfico. Todos los derechos reservados.</p>
	</div>
</footer>

<style>
	.footer {
		background: var(--color-black);
		color: var(--color-white);
		padding: 3rem 1.5rem 0;
	}

	.footer-inner {
		max-width: 1200px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem;
		padding-bottom: 2.5rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
	}

	.footer-logo {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 1rem;
	}

	.footer-logo-text {
		font-weight: 800;
		font-size: 1.05rem;
		color: var(--color-white);
		display: flex;
		flex-direction: column;
		line-height: 1.1;
	}

	.footer-logo-thin {
		font-weight: 500;
		font-size: 0.55rem;
		opacity: 0.6;
		letter-spacing: 0.1em;
	}

	.footer-tagline {
		opacity: 0.65;
		font-size: 0.9rem;
		line-height: 1.6;
		max-width: 320px;
		margin-bottom: 1.5rem;
	}

	.footer-socials {
		display: flex;
		gap: 0.75rem;
	}

	.social-icon {
		width: 38px;
		height: 38px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.08);
		color: var(--color-white);
		transition: background 0.2s ease, color 0.2s ease;
	}

	.social-icon:hover {
		background: var(--color-magenta);
	}

	.footer-heading {
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		opacity: 0.6;
		margin-bottom: 1.1rem;
	}

	.footer-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.footer-link {
		opacity: 0.85;
		font-size: 0.9rem;
		transition: opacity 0.2s ease;
	}

	.footer-link:hover {
		opacity: 1;
		color: var(--color-yellow);
	}

	.footer-contact-item {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-size: 0.9rem;
		opacity: 0.85;
	}

	.footer-bottom {
		max-width: 1200px;
		margin: 0 auto;
		padding: 1.5rem 0;
		text-align: center;
	}

	.footer-bottom p {
		font-size: 0.8rem;
		opacity: 0.5;
	}

	@media (min-width: 768px) {
		.footer-inner {
			grid-template-columns: 2fr 1fr 1fr;
		}
	}
</style>
